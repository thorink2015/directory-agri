# Google Analytics 4
# Get your Measurement ID from: Google Analytics → Admin → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Formspree Form ID
# Create a form at formspree.io, copy the form ID (e.g. xpwavqrl)
NEXT_PUBLIC_FORMSPREE_ID=

# Site URL (used for canonical URLs and sitemap)
# Change this to your actual domain once purchased
NEXT_PUBLIC_SITE_URL=https://droneagricol.ro
